    "check-types": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "latest",
    "pg": "^8.22.0"
  },
  "devDependencies": {
    "@lovable/typescript-config": "workspace:*",
    "prisma": "latest",
    "typescript": "latest"
  },
  "exports": {
    ".": "./src/index.ts"
  }
}
