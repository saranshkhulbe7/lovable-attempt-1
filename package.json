{
  "name": "lovable",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "check-types": "turbo run check-types",
    "frontend:dev": "bun --filter @lovable/frontend dev",
    "backend:dev": "bun --filter @lovable/backend dev",
    "db:generate": "turbo run db:generate --filter=@lovable/db ",
    "db:migrate:local": "turbo run db:migrate:local --filter=@lovable/db --",
    "infra:local:up": "docker compose -f infra/docker/docker-compose.local.yml up -d",
    "infra:local:down": "docker compose -f infra/docker/docker-compose.local.yml down",
    "infra:local:down:hard": "docker compose -f infra/docker/docker-compose.local.yml down -v"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "turbo": "latest",
    "typescript": "latest"
  }
}
